@page "/Admin/Import"
@model ImportModel
@{
    ViewData["Title"] = "Import";
}

<div class="mx-auto max-w-4xl space-y-10 pb-8">
    @if (!string.IsNullOrEmpty(Model.FlashMessage))
    {
        <div class="rounded-2xl border border-ink/12 bg-white/45 px-5 py-4 text-sm font-medium text-ink shadow-float backdrop-blur-[10px] ring-1 ring-gold-500/20" role="status">
            @Model.FlashMessage
        </div>
    }

    <header class="rounded-2xl border border-ink/10 bg-white/35 px-6 py-8 text-center shadow-float backdrop-blur-[10px] sm:px-10">
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-ink/45">Bookish Ink &amp; Paper</p>
        <h1 class="mt-2 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Import &amp; ledger</h1>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-ink/60 sm:text-base">
            Upload your TikTok <strong class="text-ink">.xlsx</strong> export, paste a payload below, or clear inventory. Gold accents mark primary actions.
        </p>
    </header>

    <section class="rounded-2xl border border-ink/10 bg-white/35 p-6 shadow-float backdrop-blur-[10px] sm:p-8">
        <div class="mb-6 border-b border-ink/10 pb-4">
            <h2 class="font-display text-xl font-semibold text-ink sm:text-2xl">TikTok Excel import</h2>
            <p class="mt-2 max-w-prose text-sm text-ink/60">
                Use the TikTok <strong class="text-ink">Template</strong> sheet. Row 1 uses internal headers (<strong class="text-gold-600">product_id</strong>, <strong class="text-gold-600">product_name</strong>, <strong class="text-gold-600">price</strong>, <strong class="text-gold-600">main_image</strong>, <strong class="text-gold-600">product_description</strong>) — we match those and the human labels too.
                Add your listings from <strong class="text-ink">row 6</strong> downward. Rows upsert by numeric <strong class="text-ink">Product ID</strong>. You&rsquo;ll land on the shop with a short status message.
            </p>
        </div>
        <form method="post" enctype="multipart/form-data" asp-page="/Admin/Import" asp-page-handler="Import" class="space-y-6">
            <div>
                <label asp-for="TikTokWorkbook" class="mb-3 block text-xs font-semibold uppercase tracking-widest text-gold-600">Workbook (.xlsx)</label>
                <div class="rounded-2xl border-2 border-dashed border-gold-500/45 bg-white/30 px-4 py-10 text-center shadow-inner backdrop-blur-md transition-colors hover:border-gold-500/65 hover:bg-white/40">
                    <input asp-for="TikTokWorkbook"
                           type="file"
                           accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                           class="block w-full cursor-pointer text-sm text-gold-600 file:mr-4 file:cursor-pointer file:rounded-xl file:border file:border-gold-500/50 file:bg-gold-500/10 file:px-5 file:py-2.5 file:text-sm file:font-semibold file:text-gold-600 file:backdrop-blur-sm hover:file:bg-gold-500/20" />
                    <p class="mt-4 text-xs text-ink/50">TikTok Seller Center export &middot; first row must be headers</p>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <button type="submit" class="magical-glow-btn rounded-xl bg-gold-500 px-7 py-3 text-sm font-semibold text-ink shadow-md transition hover:bg-gold-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500/40">
                    Import &amp; open shop
                </button>
                <a asp-page="/Catalog" class="text-sm font-semibold text-ink/70 transition hover:text-gold-600">Back to shop</a>
            </div>
        </form>
    </section>

    @if (Model.LastResult is { } r)
    {
        <div class="rounded-2xl border px-6 py-5 text-sm shadow-float backdrop-blur-[10px] ring-1 @(r.Ok ? "border-ink/10 bg-emerald-50/40 text-emerald-950 ring-emerald-200/40" : "border-ink/10 bg-red-50/45 text-red-950 ring-red-200/40")" role="status">
            @if (r.Ok)
            {
                <p class="font-semibold">Sync complete — created @r.Created, updated @r.Updated@(r.Skipped > 0 ? $", skipped {r.Skipped}" : "").</p>
            }
            else
            {
                <p class="font-semibold">Sync failed.</p>
            }
            @if (r.Messages.Count > 0)
            {
                <ul class="mt-3 max-h-48 list-inside list-disc space-y-1 overflow-y-auto text-xs opacity-95">
                    @foreach (var m in r.Messages)
                    {
                        <li>@m</li>
                    }
                </ul>
            }
        </div>
    }

    <section class="rounded-2xl border border-ink/10 bg-white/35 p-6 shadow-float backdrop-blur-[10px] sm:p-8">
        <div class="mb-6 border-b border-ink/10 pb-4">
            <h2 class="font-display text-xl font-semibold text-ink sm:text-2xl">Full TikTok sync</h2>
            <p class="mt-2 max-w-prose text-sm leading-relaxed text-ink/60">
                Paste a <strong class="text-ink">CSV export</strong> or <strong class="text-ink">JSON</strong> from TikTok Seller Center. Columns are read as-is (name, price, image, description, TikTok id). Rows upsert by TikTok id when present, otherwise by name.
            </p>
        </div>
        <form method="post" asp-page="/Admin/Import" asp-page-handler="CastSyncSpell" class="space-y-5">
            <div>
                <label asp-for="MagicPaste" class="mb-2 block text-xs font-semibold uppercase tracking-widest text-ink/45">Payload</label>
                <textarea asp-for="MagicPaste"
                          rows="24"
                          class="scribe-ink-textarea min-h-[min(60vh,32rem)] w-full resize-y px-5 py-5 font-mono text-sm leading-relaxed backdrop-blur-sm placeholder:text-ink/35"
                          placeholder="Paste CSV (headers) or JSON array here…"></textarea>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <button type="submit" class="rounded-xl bg-gold-500 px-8 py-3 text-sm font-bold text-ink shadow-lg transition hover:bg-gold-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500/40">
                    Run sync
                </button>
                <a asp-page="/Admin/Sync" class="text-sm font-semibold text-ink/70 transition hover:text-gold-600">Classic sync UI</a>
            </div>
        </form>
    </section>

    <section class="rounded-2xl border border-red-300/50 bg-red-50/20 p-6 shadow-float backdrop-blur-[10px] ring-1 ring-red-200/45 sm:p-8">
        <h2 class="font-display text-lg font-semibold text-red-950 sm:text-xl">Clear all inventory</h2>
        <p class="mt-2 text-sm leading-relaxed text-red-950/85">
            Removes <strong>all products</strong> from the shop. The database file stays; only product rows are deleted. This cannot be undone.
        </p>
        <form method="post"
              asp-page="/Admin/Import"
              asp-page-handler="ClearAllInventory"
              class="mt-5"
              onsubmit="return confirm('CLEAR ALL INVENTORY\n\nThis will permanently delete every product from your shop. Customers will see an empty catalog until you import again.\n\nClick OK only if you are certain.');">
            <button type="submit" class="rounded-xl border-2 border-red-700 bg-red-600 px-6 py-3 text-sm font-bold text-white shadow-md transition hover:bg-red-700 hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-red-400 focus-visible:ring-offset-2 focus-visible:ring-offset-paper">
                Clear all inventory
            </button>
        </form>
    </section>

    <section class="rounded-2xl border border-red-300/45 bg-red-50/15 p-6 shadow-float backdrop-blur-[10px] ring-1 ring-red-200/35 sm:p-8">
        <h2 class="font-display text-lg font-semibold text-red-950">Reset database</h2>
        <p class="mt-2 text-sm text-red-950/85">
            Deletes the SQLite library schema and data, recreates tables, and runs startup cleanup (no default demo products).
        </p>
        <form method="post"
              asp-page="/Admin/Import"
              asp-page-handler="ResetDatabase"
              class="mt-4"
              onsubmit="return confirm('This permanently deletes all products and cart-related data in the library database. Continue?');">
            <button type="submit" class="rounded-xl border border-red-400/80 bg-white/60 px-5 py-2.5 text-sm font-bold text-red-900 shadow-sm backdrop-blur-sm transition hover:bg-red-100">
                Reset database
            </button>
        </form>
    </section>
</div>
