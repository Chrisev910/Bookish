@page
@model CartModel
@{
    ViewData["Title"] = "Satchel";
}

<div class="mx-auto max-w-3xl text-center">
    <h1 class="font-display text-4xl font-semibold text-ink">Your satchel</h1>
    <p class="mt-3 text-ink/60">Review your picks before we send you to secure checkout.</p>
</div>

@if (!string.IsNullOrEmpty(Model.CartError))
{
    <div class="mx-auto mt-8 max-w-3xl rounded-2xl border border-gold-500/35 bg-white/50 px-4 py-3 text-sm text-ink shadow-sm backdrop-blur-sm" role="alert">
        @Model.CartError
    </div>
}

<div class="mx-auto mt-10 max-w-3xl">
    @if (Model.Lines.Count == 0)
    {
        <p class="rounded-2xl border border-dashed border-ink/15 bg-white/35 px-6 py-12 text-center text-ink/60 backdrop-blur-sm">
            Nothing here yet. Browse the <a asp-page="/Catalog" class="font-semibold text-ink underline decoration-gold-500/55 underline-offset-2 hover:text-gold-600">shop</a> to fill your satchel.
        </p>
    }
    else
    {
        <div class="overflow-hidden rounded-2xl border border-ink/10 bg-white/35 shadow-float backdrop-blur-[10px]">
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="border-b border-ink/10 bg-white/40 text-xs font-semibold uppercase tracking-wider text-ink/50">
                        <th class="px-5 py-3">Item</th>
                        <th class="px-3 py-3 text-right">Qty</th>
                        <th class="px-3 py-3 text-right">Each</th>
                        <th class="px-5 py-3 text-right">Line</th>
                        <th class="px-3 py-3 text-right"><span class="sr-only">Remove</span></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-ink/10">
                    @foreach (var line in Model.Lines)
                    {
                        <tr class="@(line.IsUnavailable ? "bg-amber-500/10 text-ink/80" : "text-ink")">
                            <td class="px-5 py-3 font-medium">@line.Name</td>
                            <td class="px-3 py-3 text-right tabular-nums">@line.Quantity</td>
                            <td class="px-3 py-3 text-right tabular-nums text-ink/60">@(line.IsUnavailable ? "—" : line.UnitPrice.ToString("C"))</td>
                            <td class="px-5 py-3 text-right tabular-nums font-semibold text-ink">@(line.IsUnavailable ? "—" : (line.UnitPrice * line.Quantity).ToString("C"))</td>
                            <td class="px-3 py-3 text-right">
                                <form method="post" asp-page-handler="Remove" class="inline">
                                    <input type="hidden" name="productId" value="@line.ProductId" />
                                    <button type="submit"
                                            class="rounded-lg border border-ink/15 bg-white/50 px-2.5 py-1 text-xs font-medium text-ink/70 transition hover:border-gold-500/40 hover:bg-white/80 hover:text-gold-600"
                                            title="Remove from satchel"
                                            aria-label="Remove @line.Name from satchel">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="border-t border-ink/10 bg-white/30 text-ink">
                        <th colspan="3" class="px-5 py-4 text-right text-sm font-semibold">Subtotal</th>
                        <th class="px-5 py-4 text-right font-display text-lg font-semibold tabular-nums">@Model.Subtotal.ToString("C")</th>
                        <th class="px-3 py-4" aria-hidden="true"></th>
                    </tr>
                </tfoot>
            </table>
        </div>

        @if (Model.HasInvalidLines)
        {
            <p class="mx-auto mt-8 max-w-lg rounded-2xl border border-amber-500/40 bg-amber-500/10 px-5 py-4 text-center text-sm text-ink shadow-sm">
                Remove the highlighted lines above (they no longer exist in the library), then you can continue to Stripe checkout.
            </p>
        }
        else
        {
            <form asp-controller="Stripe" asp-action="CreateCheckoutSession" method="post" class="mt-8 flex flex-col items-center gap-3" data-checkout-loading>
                <button type="submit" class="rounded-2xl bg-gold-500 px-10 py-3.5 text-sm font-bold text-ink shadow-lg shadow-gold-500/25 transition hover:bg-gold-600 hover:shadow-xl">
                    Checkout with Stripe
                </button>
                <p class="max-w-md text-center text-xs text-ink/50">Shipping address is collected at checkout.</p>
            </form>
        }
    }
</div>
