@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="mx-auto max-w-lg py-12 text-center">
    <h1 class="font-display text-3xl font-semibold text-ink">Something went wrong</h1>
    <p class="mt-4 text-ink/60">We couldn&rsquo;t complete that request. Please try again.</p>
    @if (Model.ShowRequestId)
    {
        <p class="mt-6 font-mono text-xs text-ink/45">Request ID: @Model.RequestId</p>
    }
    <div class="mt-10 rounded-2xl border border-gold-500/30 bg-white/40 p-5 text-sm text-ink/75 backdrop-blur-sm">
        <p class="font-medium text-ink">Development tip</p>
        <p class="mt-2 text-ink/65">Swapping to the Development environment displays detailed information about the error. Do not enable Development in production.</p>
    </div>
    <a asp-page="/Index" class="mt-8 inline-flex text-sm font-semibold text-ink underline decoration-gold-500/50 underline-offset-2 hover:text-gold-600">Return home</a>
</div>
