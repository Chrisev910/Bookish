@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="mx-auto max-w-3xl py-6 text-center sm:py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.28em] text-gold-600">Bookish Ink &amp; Paper</p>
    <h1 class="mt-4 font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl md:text-6xl">Stories you can hold</h1>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-ink/65">
        Curated wares and quiet luxuries for shelves that feel like portals.
    </p>
    <a asp-page="/Catalog" class="mt-10 inline-flex items-center justify-center rounded-2xl bg-gold-500 px-8 py-3.5 text-sm font-semibold text-ink shadow-lg shadow-gold-500/20 transition hover:bg-gold-600 hover:shadow-xl">
        Browse the collection
    </a>
</div>
