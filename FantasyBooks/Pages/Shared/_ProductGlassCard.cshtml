@model FantasyBooks.Models.Product

@{
    var descPreview = HtmlPlainText.PreviewForCard(Model.Description);
}

<div class="group h-full">
    <div class="product-card flex h-full flex-col overflow-hidden rounded-2xl border border-ink/12 bg-white/35 shadow-float backdrop-blur-[12px] transition duration-300 ease-out hover:border-gold-500/35 hover:shadow-float-hover">
        <a asp-page="/Product" asp-route-id="@Model.Id" class="block rounded-t-2xl text-ink no-underline outline-none transition focus-visible:ring-2 focus-visible:ring-gold-500/50 focus-visible:ring-offset-2 focus-visible:ring-offset-paper">
            <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-ink/5 to-gold-500/5">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="" class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.03]" loading="lazy" />
                }
                else
                {
                    <div class="flex h-full min-h-[11rem] items-center justify-center text-5xl text-ink/15" aria-hidden="true">✦</div>
                }
            </div>
            <div class="product-card-meta space-y-1 px-6 pt-6 pb-1">
                <h2 class="font-display text-xl font-semibold leading-snug text-ink group-hover:text-gold-600 sm:text-2xl">@Model.Name</h2>
                <p class="product-card-price font-display text-2xl font-semibold tabular-nums text-ink sm:text-3xl">@Model.Price.ToString("C")</p>
            </div>
        </a>
        <div class="flex flex-1 flex-col gap-4 px-6 pb-6 pt-4">
            @if (!string.IsNullOrWhiteSpace(descPreview))
            {
                <p class="line-clamp-4 text-sm leading-relaxed text-ink/65">@descPreview</p>
            }
            <div class="mt-auto border-t border-ink/10 pt-4">
                <form method="post" asp-page="/Catalog" asp-page-handler="AddToCart" class="inline w-full">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    @if (ViewData["CatalogSearch"] is string catalogSearch && !string.IsNullOrWhiteSpace(catalogSearch))
                    {
                        <input type="hidden" name="search" value="@catalogSearch" />
                    }
                    <button type="submit" class="magical-glow-btn w-full rounded-xl bg-gold-500 px-4 py-3 text-sm font-semibold text-ink shadow-md transition hover:bg-gold-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500/50 focus-visible:ring-offset-2 focus-visible:ring-offset-paper">
                        Add to Satchel
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
